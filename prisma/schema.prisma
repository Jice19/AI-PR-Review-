generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========== 用户 ==========
model User {
  id            String    @id @default(uuid())
  githubId      String?   @unique
  name          String
  email         String?
  emailVerified DateTime?
  image         String?
  avatar        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  reviews   Review[]
  policies  ReviewPolicy[]
}

// ========== NextAuth 账户关联 ==========
model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// ========== NextAuth 会话 ==========
model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ========== NextAuth 验证令牌 ==========
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ========== 审查记录 ==========
model Review {
  id            String   @id @default(uuid())
  prUrl         String
  prTitle       String
  repoName      String
  branchFrom    String
  branchTo      String
  status        String   @default("PENDING") // PENDING | FETCHING | ANALYZING | SUGGESTING | COMPLETED | FAILED
  summary       String?  @db.Text           // PR 变更总结 (markdown)
  metadata      Json?                       // { filesChanged, additions, deletions }
  overallScore  Float?                      // 综合评分 0-100
  decision      String?                     // APPROVE | COMMENT | REQUEST_CHANGES
  decisionReason String? @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId       String
  user         User          @relation(fields: [userId], references: [id])
  policyId     String?
  policy       ReviewPolicy? @relation(fields: [policyId], references: [id])
  stageResults StageResult[]
  issues       ReviewIssue[]
  auditLogs    AuditLog[]
  contextFiles ContextFile[]

  @@index([userId])
  @@index([repoName])
  @@index([status])
  @@index([createdAt])
}

// ========== 阶段审查结果 ==========
model StageResult {
  id       String @id @default(uuid())
  stage    String // SUMMARY | BACKEND_SECURITY | BACKEND_LOGIC | ...
  status   String // PASSED | WARNING | FAILED
  summary  String @db.Text
  score    Float  // 0-100
  reviewId String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  issues ReviewIssue[]

  @@index([reviewId])
}

// ========== 代码问题 ==========
model ReviewIssue {
  id          String @id @default(uuid())
  filePath    String
  lineStart   Int
  lineEnd     Int
  layer       String  // FRONTEND | BACKEND | DATABASE | CONFIG
  severity    String  // CRITICAL | HIGH | MEDIUM | LOW
  category    String  // INJECTION | XSS | N_PLUS_ONE | ...
  title       String
  description String  @db.Text
  codeSnippet String  @db.Text
  suggestion  Json?   // 修复建议 JSON
  confidence  Float   // 0.0 - 1.0
  source      String  // rule-engine | semgrep | llm
  ruleId      String?
  createdAt   DateTime @default(now())

  reviewId     String
  review       Review      @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  stageResultId String?
  stageResult  StageResult? @relation(fields: [stageResultId], references: [id], onDelete: SetNull)
  feedbacks    IssueFeedback[]

  @@index([reviewId])
  @@index([severity])
  @@index([layer])
}

// ========== 反馈类型 ==========
enum FeedbackType {
  USEFUL
  FALSE_POSITIVE
  NEEDS_REVIEW
}

// ========== Issue 反馈 ==========
model IssueFeedback {
  id        String       @id @default(uuid())
  issueId   String
  feedback  FeedbackType
  comment   String?      @db.Text
  createdBy String
  createdAt DateTime     @default(now())

  issue ReviewIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@unique([issueId])
  @@index([issueId])
}

// ========== LLM 审计日志 ==========
model AuditLog {
  id            String   @id @default(uuid())
  reviewId      String
  model         String
  stage         String
  promptChars   Int
  responseChars Int
  totalTokens   Int?
  durationMs    Int
  fileCount     Int?
  success       Boolean
  errorMsg      String?  @db.Text
  createdAt     DateTime @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@index([createdAt])
  @@index([model])
}

// ========== 审查策略 ==========
model ReviewPolicy {
  id          String   @id @default(uuid())
  name        String
  description String?  @db.Text
  config      Json     // ReviewPolicyConfig JSON
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId  String
  user    User     @relation(fields: [userId], references: [id])
  reviews Review[]

  @@index([userId])
}

// ========== 上下文文件索引 ==========
model ContextFile {
  id          String   @id @default(uuid())
  filePath    String
  fileType    String   // changed | related
  contentHash String
  storageKey  String
  size        Int
  createdAt   DateTime @default(now())

  reviewId String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@index([contentHash])
  @@index([filePath])
}
